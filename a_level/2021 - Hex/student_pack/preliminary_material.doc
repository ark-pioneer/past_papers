\clbrdrt\brdrs\brdrw15\brdrcf1\clbrdrr\brdrs\brdrw15\brdrcf1\clbrdrb\brdrs\brdrw15\brdrcf1\clbrdrl\brdrs\brdrw15\brdrcf1\clvertalt
\cellx6690
\clbrdrt\brdrs\brdrw15\brdrcf1\clbrdrr\brdrs\brdrw15\brdrcf1\clbrdrb\brdrs\brdrw15\brdrcf1\clbrdrl\brdrs\brdrw15\brdrcf1\clvertalt
\cellx8370
\intbl\f1\fs22\cf0\ltrpar\ql\sb90\sa90\li45\ri45 Serf (the standard piece)
\intbl \cell
\intbl\f1\fs22\cf0\ltrpar\ql\sb90\sa90\li45\ri45 Can move to any neighbouring tile.\par
\intbl\f1\fs22\cf0\ltrpar\ql\sb90\sa90\li45\ri45 This movement costs one fuel unless it is moving to or from a peat bog tile in which case it costs two fuel.
\intbl \cell
\intbl\f1\fs22\cf0\ltrpar\ql\sb90\sa90\li45\ri45 \~
\intbl \cell
\intbl\f1\fs22\cf0\ltrpar\ql\sb90\sa90\li45\ri45 Worth one victory point for opponent if destroyed.
\intbl \cell\pard\intbl\row\pard

